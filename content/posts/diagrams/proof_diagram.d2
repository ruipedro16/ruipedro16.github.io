style: {
  fill: transparent
}

JasminSource: "Jasmin Source Code"
EasyCryptModel: "EasyCrypt Model"
EasyCryptSpec: "EasyCrypt Specification"
x86Assembly: "x86_64 Assembly"

JasminSource -> EasyCryptModel: "extracts to"
